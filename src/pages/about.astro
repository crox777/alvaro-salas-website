---
import BaseLayout from '../layouts/BaseLayout.astro';
import { Image } from 'astro:assets';
import alvaroPhoto from '../assets/alvaro-salas-off.png';
---

<BaseLayout title="About" description="Dr. Alvaro A. Salas-Castro: President & CEO of The Reynolds Foundation, Cornell lecturer, and advocate for making freedom investible.">
	<div class="mx-auto max-w-4xl px-6 py-16">
		<header class="mb-16">
			<h1 class="text-4xl font-bold md:text-5xl">About</h1>
			<p class="mt-4 text-xl text-text-secondary">
				From crowdfunding an Ivy League education to leading a foundation deploying $60M+ to freedom.
			</p>
		</header>

		<!-- Photo + Bio -->
		<section class="grid gap-12 md:grid-cols-[280px_1fr] items-start">
			<div class="relative">
				<Image
					src={alvaroPhoto}
					alt="Dr. Alvaro A. Salas-Castro"
					width={280}
					class="w-full rounded-sm border border-border"
				/>
				<div class="absolute inset-0 rounded-sm border border-amber/10 pointer-events-none"></div>
			</div>
			<div class="prose max-w-none">
				<p class="text-lg leading-relaxed text-text">
					Dr. Alvaro A. Salas-Castro is the President & CEO of The Reynolds Foundation and the Reynolds
					Family Office, where he leads a mission to make freedom investible. Under his leadership, the
					Foundation has funded 90+ organizations across 62+ countries, deploying over $60 million to
					advance freedom, rule of law, and democratic governance.
				</p>
				<p class="text-lg leading-relaxed text-text">
					A Costa Rican-born lawyer, economist, and public policy scholar, Alvaro's career spans
					government advising, international development, and academic leadership. He serves as a
					Lecturer at Cornell's Jeb E. Brooks School of Public Policy, teaching "Navigating
					Public-Private Partnerships," and holds affiliate faculty positions at Syracuse University's
					Maxwell School and INCAE Business School.
				</p>
			</div>
		</section>

		<!-- Timeline -->
		<section class="mt-20">
			<h2 class="mb-8 text-2xl font-bold">Career Timeline</h2>
			<div class="relative border-l-2 border-border pl-8 space-y-10">
				{[
					{ year: 'Present', title: 'President & CEO', org: 'The Reynolds Foundation & Reynolds Family Office', desc: 'Leading freedom investment strategy. 90+ orgs funded, 62+ countries, $60M+ deployed.' },
					{ year: 'Present', title: 'Lecturer', org: 'Cornell Jeb E. Brooks School of Public Policy', desc: 'Teaching "Navigating Public-Private Partnerships" in the Executive MPA program.' },
					{ year: 'Present', title: 'Founder & Host', org: 'BLISS Summit', desc: 'Annual invitation-only gathering of 100+ leaders deploying capital to freedom.' },
					{ year: '2020', title: 'Founder & Emeritus Chairman', org: 'DemoLab Foundation', desc: 'Costa Rica-based civic innovation think tank. Freedom Curriculum, FWD Tech, Nosara Research Project.' },
					{ year: '2018', title: 'Affiliate Faculty', org: 'Syracuse Maxwell School & INCAE Business School', desc: 'Teaching and research on public-private partnerships and institutional reform.' },
					{ year: '2014', title: 'MPA, Cornell University', org: 'Science, Technology & Infrastructure', desc: 'Graduated with highest honors. First Latin American President of the Cornell Public Affairs Society.' },
					{ year: 'Prior', title: 'Government Advisor & Consultant', org: 'Panama, Costa Rica, IDB, UN, Grameen', desc: 'Special Advisor to governments. Consultant for Inter-American Development Bank, United Nations (UNDESA), and Grameen Creative Lab.' },
				].map(({ year, title, org, desc }) => (
					<div class="relative">
						<div class="absolute -left-[calc(2rem+5px)] top-1.5 h-2.5 w-2.5 rounded-full bg-amber" />
						<span class="text-xs font-semibold uppercase tracking-wider text-amber">{year}</span>
						<h3 class="mt-1 text-lg font-bold">{title}</h3>
						<p class="text-sm font-medium text-text-secondary">{org}</p>
						<p class="mt-1 text-sm text-text-secondary leading-relaxed">{desc}</p>
					</div>
				))}
			</div>
		</section>

		<!-- Education -->
		<section class="mt-20">
			<h2 class="mb-8 text-2xl font-bold">Education</h2>
			<div class="space-y-4">
				{[
					{ degree: 'Ph.D., Administration, International Affairs & Public Policy', school: 'Syracuse University (Maxwell School)' },
					{ degree: 'MPA, Science, Technology & Infrastructure', school: 'Cornell University, Highest Honors' },
					{ degree: 'MBA, Finance, Economics & Sustainable Development', school: 'INCAE Business School, Leaders for Change Scholar' },
					{ degree: 'J.D. (Law)', school: 'Autonomous University of Central America' },
					{ degree: 'B.A., International Relations', school: 'Universidad Latina' },
				].map(({ degree, school }) => (
					<div class="rounded-sm border border-border bg-surface p-4">
						<p class="font-bold">{degree}</p>
						<p class="text-sm text-text-secondary">{school}</p>
					</div>
				))}
			</div>
		</section>

		<!-- Honors -->
		<section class="mt-20">
			<h2 class="mb-8 text-2xl font-bold">Honors & Awards</h2>
			<ul class="space-y-3">
				{[
					'First Latin American President of the Cornell Public Affairs Society',
					'Presidential Fellow, Center for the Study of the Presidency and Congress (Washington, D.C.)',
					'Phi Alpha Alpha National Honor Society',
					'Cornell Adams Award for "exemplary scholarship and service in the field of public affairs"',
				].map((honor) => (
					<li class="flex items-start gap-3">
						<span class="mt-1.5 h-1.5 w-1.5 flex-shrink-0 rounded-full bg-amber" />
						<span class="text-text-secondary">{honor}</span>
					</li>
				))}
			</ul>
		</section>

		<!-- Origin Story -->
		<section class="mt-20 rounded-sm border border-amber/20 bg-amber/5 p-8">
			<h2 class="text-2xl font-bold text-amber">Origin Story</h2>
			<p class="mt-4 leading-relaxed text-text-secondary">
				As a young Costa Rican lawyer with an MBA, Alvaro crowdfunded his way to Cornell's MPA
				program. His campaign became a case study in crowdfunding an Ivy League education. From there,
				he went on to advise governments, consult for the United Nations and Inter-American Development
				Bank, and ultimately lead The Reynolds Foundation in its mission to make freedom investible.
			</p>
		</section>
	</div>
</BaseLayout>
