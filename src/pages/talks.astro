---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const allTalks = await getCollection('talks');
const talks = allTalks.sort((a, b) => new Date(b.data.date).valueOf() - new Date(a.data.date).valueOf());
---

<BaseLayout title="Talks" description="Speaking appearances and presentations by Alvaro Salas-Castro on freedom investing, democracy, and institutional reform.">
	<div class="mx-auto max-w-6xl px-6 py-16">
		<header class="mb-12">
			<h1 class="text-4xl font-bold md:text-5xl">Talks</h1>
			<p class="mt-4 max-w-2xl text-lg text-text-secondary">
				Presentations on freedom investing, democratic resilience, and why institutions matter.
			</p>
		</header>

		{talks.length > 0 ? (
			<div class="space-y-8">
				{talks.map((talk) => (
					<div class="rounded-sm border border-border bg-surface p-6">
						<div class="flex items-center gap-3 text-xs text-text-secondary">
							<span class="font-semibold uppercase tracking-wider text-amber">Talk</span>
							<span class="text-border">|</span>
							<span>{talk.data.event}</span>
							<span class="text-border">|</span>
							<time datetime={talk.data.date.toISOString()}>
								{talk.data.date.toLocaleDateString('en-US', { year: 'numeric', month: 'long' })}
							</time>
						</div>
						<h3 class="mt-3 text-xl font-bold">{talk.data.title}</h3>
						{talk.data.description && (
							<p class="mt-2 text-sm text-text-secondary">{talk.data.description}</p>
						)}
						{talk.data.videoUrl && (
							<div class="mt-4 aspect-video overflow-hidden rounded-sm">
								<iframe
									src={talk.data.videoUrl.replace('watch?v=', 'embed/')}
									class="h-full w-full"
									allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
									allowfullscreen
								></iframe>
							</div>
						)}
						<div class="mt-4 flex gap-4">
							{talk.data.videoUrl && (
								<a href={talk.data.videoUrl} target="_blank" rel="noopener" class="text-sm font-semibold text-amber hover:underline">
									Watch Video &rarr;
								</a>
							)}
							{talk.data.slidesUrl && (
								<a href={talk.data.slidesUrl} target="_blank" rel="noopener" class="text-sm font-semibold text-text-secondary hover:text-amber transition-colors">
									View Slides &rarr;
								</a>
							)}
						</div>
					</div>
				))}
			</div>
		) : (
			<div class="rounded-sm border border-border bg-surface p-12 text-center">
				<p class="text-text-secondary">Talk recordings and presentations coming soon.</p>
			</div>
		)}
	</div>
</BaseLayout>
