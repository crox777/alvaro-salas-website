---
import BaseLayout from '../layouts/BaseLayout.astro';
import ContentCard from '../components/ContentCard.astro';
import { getCollection } from 'astro:content';
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';

// Get latest content across all collections
const ideas = await getCollection('ideas');
const talks = await getCollection('talks');
const podcasts = await getCollection('podcasts');

type ContentItem = { title: string; date: Date; href: string; type: 'idea' | 'talk' | 'podcast'; description?: string; topic?: string };

const allContent: ContentItem[] = [
	...ideas.map((i) => ({ title: i.data.title, date: new Date(i.data.pubDate), href: `/ideas/${i.id}`, type: 'idea' as const, description: i.data.description, topic: i.data.topic })),
	...talks.map((t) => ({ title: t.data.title, date: new Date(t.data.date), href: `/talks`, type: 'talk' as const, description: t.data.description })),
	...podcasts.map((p) => ({ title: p.data.title, date: new Date(p.data.date), href: `/podcasts`, type: 'podcast' as const, description: p.data.description })),
];

const latest = allContent.sort((a, b) => b.date.valueOf() - a.date.valueOf()).slice(0, 4);
---

<BaseLayout title={SITE_TITLE} description={SITE_DESCRIPTION}>
	<div class="mx-auto max-w-6xl px-6">
		<!-- Hero -->
		<section class="py-24 md:py-32">
			<p class="mb-4 text-sm font-semibold uppercase tracking-wider text-amber">President & CEO, The Reynolds Foundation</p>
			<h1 class="text-5xl font-bold leading-[1.1] md:text-7xl">
				Alvaro<br />Salas-Castro
			</h1>
			<p class="mt-6 max-w-xl text-xl text-text-secondary">
				Making Freedom Investible.
			</p>

			<!-- Stats -->
			<div class="mt-10 flex flex-wrap gap-8 border-t border-border pt-8">
				<div>
					<span class="text-3xl font-bold text-amber">90+</span>
					<p class="text-sm text-text-secondary">Organizations Funded</p>
				</div>
				<div>
					<span class="text-3xl font-bold text-amber">62+</span>
					<p class="text-sm text-text-secondary">Countries</p>
				</div>
				<div>
					<span class="text-3xl font-bold text-amber">$60M+</span>
					<p class="text-sm text-text-secondary">Deployed to Freedom</p>
				</div>
			</div>

			<!-- CTAs -->
			<div class="mt-10 flex flex-wrap gap-4">
				<a href="/ideas" class="inline-flex items-center gap-2 rounded-sm bg-amber px-6 py-3 text-sm font-semibold text-bg transition-colors hover:bg-amber-hover">
					Read the Thesis
					<svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" /></svg>
				</a>
				<a href="/speaking" class="inline-flex items-center gap-2 rounded-sm border border-text-secondary px-6 py-3 text-sm font-semibold text-text transition-colors hover:border-amber hover:text-amber">
					Book Alvaro
				</a>
			</div>
		</section>

		<!-- Start Here -->
		<section class="border-t border-border py-20">
			<h2 class="mb-2 text-xs font-semibold uppercase tracking-wider text-amber">Start Here</h2>
			<h3 class="text-3xl font-bold md:text-4xl">The Mispricing of Freedom</h3>
			<div class="mt-6 max-w-2xl space-y-4 text-text-secondary leading-relaxed">
				<p>
					Less than 1% of U.S. charitable giving goes to democracy and freedom work. This represents
					a massive misallocation. Freedom is the foundational infrastructure that makes all other
					philanthropic goals possible.
				</p>
				<p>
					Observable democratic and liberty outcomes improve market performance over time. Family offices
					can identify and invest in "freedom alpha" as a measurable metric. Robust institutions and
					rule of law create 20%+ GDP growth over 25 years and attract capital.
				</p>
				<p>
					If we want to defeat dictators and reclaim the future of freedom, we must stop
					reacting — and start investing.
				</p>
			</div>
			<a href="/ideas" class="mt-6 inline-flex items-center gap-2 text-sm font-semibold text-amber hover:underline">
				Read the full thesis
				<svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" /></svg>
			</a>
		</section>

		<!-- Latest -->
		{latest.length > 0 && (
			<section class="border-t border-border py-20">
				<h2 class="mb-2 text-xs font-semibold uppercase tracking-wider text-amber">Latest</h2>
				<h3 class="mb-10 text-3xl font-bold">Recent Ideas, Talks & Conversations</h3>
				<div class="grid gap-6 md:grid-cols-2">
					{latest.map((item) => (
						<ContentCard
							title={item.title}
							description={item.description}
							date={item.date}
							topic={item.topic}
							href={item.href}
							type={item.type}
						/>
					))}
				</div>
			</section>
		)}

		<!-- Projects -->
		<section class="border-t border-border py-20">
			<h2 class="mb-2 text-xs font-semibold uppercase tracking-wider text-amber">Projects</h2>
			<h3 class="mb-10 text-3xl font-bold">Building Freedom Infrastructure</h3>
			<div class="grid gap-6 md:grid-cols-2">
				{[
					{
						name: 'BLISS Summit',
						desc: 'Annual invitation-only gathering of 100+ leaders — philanthropists, technologists, artists, and dissidents — deploying capital to freedom initiatives.',
						href: '/projects/bliss-summit',
					},
					{
						name: 'Reynolds Freedom Accelerator',
						desc: 'Three-pillar model: Freedom Fellows, Freedom Academy, and Executive Academy. Focused on 10 most at-risk democracies.',
						href: '/projects/reynolds-freedom-accelerator',
					},
					{
						name: 'DemoLab Foundation',
						desc: 'Costa Rica-based civic innovation think tank. Freedom Curriculum, FWD Tech program, and the Nosara Research Project.',
						href: '/projects/demolab-foundation',
					},
					{
						name: 'The Reynolds Foundation',
						desc: '90+ organizations funded across 62+ countries. $60M+ deployed to advance democratic governance and rule of law.',
						href: '/projects/the-reynolds-foundation',
					},
				].map(({ name, desc, href }) => (
					<a href={href} class="group rounded-sm border border-border bg-surface p-6 transition-all hover:border-amber/30 hover:bg-surface-hover">
						<h4 class="text-lg font-bold group-hover:text-amber transition-colors">{name}</h4>
						<p class="mt-2 text-sm text-text-secondary leading-relaxed">{desc}</p>
						<span class="mt-4 inline-flex items-center gap-1 text-xs font-semibold text-amber opacity-0 transition-opacity group-hover:opacity-100">
							Learn more
							<svg class="h-3 w-3" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" /></svg>
						</span>
					</a>
				))}
			</div>
		</section>

		<!-- Speaking -->
		<section class="border-t border-border py-20">
			<h2 class="mb-2 text-xs font-semibold uppercase tracking-wider text-amber">Speaking</h2>
			<h3 class="text-3xl font-bold">Bringing the Message to Stages Worldwide</h3>
			<p class="mt-4 max-w-2xl text-text-secondary">
				From the Oslo Freedom Forum to TEDx Vancouver, Alvaro speaks on freedom investing,
				democratic resilience, and the moral case for institutional reform.
			</p>
			<div class="mt-8 flex flex-wrap gap-4 text-sm text-text-secondary">
				{['Oslo Freedom Forum', 'SALT Conference', 'Atlas Network', 'TEDx Vancouver', 'Cornell Brooks School', 'BLISS Summit'].map((event) => (
					<span class="rounded-sm border border-border px-3 py-1">{event}</span>
				))}
			</div>
			<a href="/speaking" class="mt-8 inline-flex items-center gap-2 rounded-sm bg-red px-6 py-3 text-sm font-semibold text-text transition-colors hover:bg-red-hover">
				Invite Alvaro to Speak
			</a>
		</section>
	</div>
</BaseLayout>
