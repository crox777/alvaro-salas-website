---
import BaseLayout from './BaseLayout.astro';

interface Props {
	title: string;
	description: string;
	pubDate?: Date;
	updatedDate?: Date;
	topic?: string;
	image?: string;
}

const { title, description, pubDate, updatedDate, topic, image } = Astro.props;
---

<BaseLayout title={title} description={description} image={image}>
	<article class="mx-auto max-w-3xl px-6 py-12">
		<!-- Header -->
		<header class="mb-12">
			{topic && (
				<span class="mb-4 inline-block text-xs font-semibold uppercase tracking-wider text-amber">
					{topic.replace('-', ' ')}
				</span>
			)}
			<h1 class="text-4xl font-bold leading-tight md:text-5xl">{title}</h1>
			{pubDate && (
				<div class="mt-4 flex items-center gap-4 text-sm text-text-secondary">
					<time datetime={pubDate.toISOString()}>
						{pubDate.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
					</time>
					{updatedDate && (
						<span>
							Updated: <time datetime={updatedDate.toISOString()}>
								{updatedDate.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
							</time>
						</span>
					)}
				</div>
			)}
			<p class="mt-4 text-lg text-text-secondary">{description}</p>
		</header>

		<!-- Content -->
		<div class="prose">
			<slot />
		</div>
	</article>
</BaseLayout>
