---
interface Props {
	title: string;
	description?: string;
	date?: Date;
	topic?: string;
	href: string;
	type?: 'idea' | 'talk' | 'podcast' | 'project';
}

const { title, description, date, topic, href, type = 'idea' } = Astro.props;

const typeColors: Record<string, string> = {
	idea: 'text-amber',
	talk: 'text-amber',
	podcast: 'text-red',
	project: 'text-amber',
};

const typeLabels: Record<string, string> = {
	idea: 'Essay',
	talk: 'Talk',
	podcast: 'Podcast',
	project: 'Project',
};
---

<a href={href} class="group card-glow block rounded-sm p-6">
	<div class="flex items-center gap-3 text-[11px] text-text-secondary">
		<span class={`font-bold uppercase tracking-widest ${typeColors[type]}`}>{typeLabels[type]}</span>
		{topic && (
			<>
				<span class="text-border/50">/</span>
				<span class="capitalize">{topic.replace('-', ' ')}</span>
			</>
		)}
		{date && (
			<>
				<span class="text-border/50">/</span>
				<time datetime={date.toISOString()}>
					{date.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' })}
				</time>
			</>
		)}
	</div>
	<h3 class="mt-3 text-lg font-bold transition-colors group-hover:text-amber leading-snug">{title}</h3>
	{description && (
		<p class="mt-2 text-sm leading-relaxed text-text-secondary line-clamp-2">{description}</p>
	)}
	<div class="mt-4 flex items-center gap-1.5 text-xs font-semibold text-amber opacity-0 transition-all group-hover:opacity-100 group-hover:translate-x-1">
		Read more
		<svg class="h-3 w-3" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" /></svg>
	</div>
</a>
