---
interface Props {
	title: string;
	description?: string;
	date?: Date;
	topic?: string;
	href: string;
	type?: 'idea' | 'talk' | 'podcast' | 'project';
}

const { title, description, date, topic, href, type = 'idea' } = Astro.props;

const typeLabels: Record<string, string> = {
	idea: 'Essay',
	talk: 'Talk',
	podcast: 'Podcast',
	project: 'Project',
};
---

<a href={href} class="group block rounded-sm border border-border bg-surface p-6 transition-all hover:border-amber/30 hover:bg-surface-hover">
	<div class="flex items-center gap-3 text-xs text-text-secondary">
		<span class="font-semibold uppercase tracking-wider text-amber">{typeLabels[type]}</span>
		{topic && (
			<>
				<span class="text-border">|</span>
				<span class="capitalize">{topic.replace('-', ' ')}</span>
			</>
		)}
		{date && (
			<>
				<span class="text-border">|</span>
				<time datetime={date.toISOString()}>
					{date.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' })}
				</time>
			</>
		)}
	</div>
	<h3 class="mt-3 text-lg font-bold transition-colors group-hover:text-amber">{title}</h3>
	{description && (
		<p class="mt-2 text-sm leading-relaxed text-text-secondary line-clamp-2">{description}</p>
	)}
</a>
